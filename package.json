{
  "name": "@alextheman/utility",
  "version": "5.25.0",
  "description": "Helpful utility functions.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alextheman231/utility.git"
  },
  "license": "MIT",
  "author": "alextheman",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./internal": {
      "types": "./dist/internal/index.d.ts",
      "import": "./dist/internal/index.js",
      "require": "./dist/internal/index.cjs"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js",
      "require": "./dist/node/index.cjs"
    },
    "./temporal": {
      "types": "./dist/temporal/index.d.ts",
      "import": "./dist/temporal/index.js",
      "require": "./dist/temporal/index.cjs"
    },
    "./v6": {
      "types": "./dist/v6/index.d.ts",
      "import": "./dist/v6/index.js",
      "require": "./dist/v6/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "build-configs": "tsdown --config tsdown.configs.config.ts",
    "create-feature-docs": "typedoc",
    "create-local-package": "pnpm run build && rm -f alextheman-utility-*.tgz && pnpm pack",
    "create-release-note": "bash -c 'git pull origin main && alex-c-line template release-note create $@' --",
    "format": "pnpm run format-prettier && pnpm run format-eslint && pnpm run format-markdownlint",
    "format-eslint": "eslint --fix --suppress-all \"package.json\" \"{src,tests,configs}/**/*.ts\" && rm -f eslint-suppressions.json",
    "format-markdownlint": "pnpm exec markdownlint-cli2 --fix \"**/*.md\" \"!{node_modules,dist}/**\" | grep -v \"^Finding:\"",
    "format-prettier": "pnpm run format-prettier-typescript && pnpm run format-prettier-javascript && pnpm run format-prettier-yml",
    "format-prettier-javascript": "prettier --write \"./**/*.js\"",
    "format-prettier-typescript": "prettier --write --parser typescript \"./**/*.ts\"",
    "format-prettier-yml": "prettier --write \"./**/*.{yml,yaml}\"",
    "lint": "pnpm run lint-tsc && pnpm run lint-eslint && pnpm run lint-markdownlint && pnpm run lint-prettier && pnpm run lint-pre-release",
    "lint-eslint": "eslint \"package.json\" \"{src,tests,configs}/**/*.ts\"",
    "lint-markdownlint": "bash -o pipefail -c 'pnpm exec markdownlint-cli2 \"**/*.md\" \"!{node_modules,dist}/**\"| grep -v \"^Finding:\"'",
    "lint-pre-release": "alex-c-line package-json check --rules no-pre-release-dependencies",
    "lint-prettier": "pnpm run lint-prettier-typescript && pnpm run lint-prettier-javascript && pnpm run lint-prettier-yml",
    "lint-prettier-javascript": "prettier --check \"./**/*.js\"",
    "lint-prettier-typescript": "prettier --check --parser typescript \"./**/*.ts\"",
    "lint-prettier-yml": "prettier --check \"./**/*.{yml,yaml}\"",
    "lint-tsc": "tsc --noEmit",
    "pre-commit": "pnpm run build-configs && alex-c-line pre-commit",
    "prepare": "husky",
    "prepare-live-eslint-plugin": "pnpm uninstall @alextheman/eslint-plugin && pnpm install --save-dev @alextheman/eslint-plugin",
    "prepare-local-eslint-plugin": "dotenv -e .env -- sh -c 'ESLINT_PLUGIN_PATH=${LOCAL_ESLINT_PLUGIN_PATH:-../eslint-plugin}; pnpm --prefix \"$ESLINT_PLUGIN_PATH\" run build && pnpm uninstall @alextheman/eslint-plugin && pnpm install --save-dev file:\"$ESLINT_PLUGIN_PATH\"'",
    "test": "vitest run",
    "test-end-to-end": "cross-env RUN_END_TO_END=true vitest run tests/end-to-end --reporter verbose",
    "test-watch": "vitest",
    "update-dependencies": "pnpm update --latest && pnpm update",
    "use-live-eslint-plugin": "pnpm run prepare-live-eslint-plugin && pnpm run lint",
    "use-local-eslint-plugin": "pnpm run prepare-local-eslint-plugin && pnpm run lint"
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "execa": "9.6.1"
  },
  "devDependencies": {
    "@alextheman/eslint-plugin": "5.18.0",
    "@types/node": "26.1.1",
    "alex-c-line": "2.12.4",
    "cross-env": "10.1.0",
    "dotenv-cli": "11.0.0",
    "eslint": "10.6.0",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "markdownlint-cli2": "0.23.0",
    "prettier": "3.9.4",
    "tempy": "3.2.0",
    "tsdown": "0.22.4",
    "tsx": "4.23.0",
    "typedoc": "0.28.20",
    "typedoc-plugin-markdown": "4.12.0",
    "typedoc-rhineai-theme": "1.2.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.3",
    "vitest": "4.1.10",
    "zod": "4.4.3"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "engines": {
    "node": ">=22.3.0"
  },
  "peerDependencies": {
    "zod": ">=4.0.0"
  }
}
